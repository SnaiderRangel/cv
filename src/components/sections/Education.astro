---
import Section from "../Section.astro"

import { education } from "@cv"
---

{education && education.length > 0 && (
<Section title="Educación">
  <ul>
    {
      education.map(({ institution, startDate, endDate, area, summary, highlights }) => {
        const startYear = new Date(startDate).getFullYear()
        const endYear =
          endDate != null ? new Date(endDate).getFullYear() : "Actual"
        const years = `${startYear} - ${endYear}`

        return (
          <li>
            <article>
              <header>
                <div>
                  <h3>{institution}</h3>
                </div>

                <time>{years}</time>
              </header>

              <footer>
                <p>{area}</p>
                {summary && <p>{summary}</p>}
                {highlights && (
                  <ul>
                    {highlights.map((highlight) => (
                      <li>{highlight}</li>
                    ))}
                  </ul>
                )}
              </footer>
            </article>
          </li>
        )
      })
    }
  </ul>
</Section>
)}

<style>
  ul {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  article h3 {
    font-weight: 500;
    color: #111;
  }

  header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 4px;
  }

  time {
    color: #555;
    font-size: 0.85rem;
    min-width: 102px;
  }

  footer p {
    color: #666;
    font-size: 0.9rem;
    line-height: 1.5;
    margin-bottom: 8px;
  }

  footer ul {
    list-style: disc;
    padding-left: 20px;
    gap: 4px;
    margin-top: 8px;
  }

  footer ul li {
    color: #666;
    font-size: 0.85rem;
  }

  @media (width <= 700px) {
    time {
      text-align: right;
    }
  }
</style>
